+/* ==========================================================
+   ERŐFORRÁS KIJELÖLÉS (panel) → timeline sorhoz görgetés
+   (B modell: a timeline továbbra is mindenkit mutat)
+========================================================== */
+function onSelectResource(type, resource) {
+  // panel kijelölés
+  document.querySelectorAll(".resource-card.selected").forEach(n => n.classList.remove("selected"));
+  const card = document.querySelector(`.resource-card[data-type="${type}"][data-id="${resource.id}"]`);
+  if (card) card.classList.add("selected");
+
+  // timeline sorhoz görgetés + ideiglenes highlight
+  const nameEl = document.querySelector(
+    `.timeline-resource-name[data-resource-type="${type}"][data-resource-id="${resource.id}"]`
+  );
+  if (!nameEl) return;
+
+  const timelineRow = nameEl.closest(".timeline-resource");
+  if (!timelineRow) return;
+
+  timelineRow.classList.add("selected");
+  timelineRow.scrollIntoView({ behavior: "smooth", block: "center" });
+  setTimeout(() => timelineRow.classList.remove("selected"), 1200);
+}
+
