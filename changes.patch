+// ============================================================
+// TransIT v4.4 – Continuous Timeline Generator (72h)
+// - Minden erőforrásnak folyamatos timeline-t generál (ha üres)
+// - Sofőr: fuvar | piheno | szabadsag | beteg  (beteg >= 24h)
+// - Vontató: fuvar | szerviz | allas
+// - Pótkocsi: fuvar | szerviz | standby
+// ============================================================
+
+const TIMELINE_HOURS = 72;
+
+function getBaseDate() {
+  const d = new Date();
+  d.setHours(0, 0, 0, 0);
+  return d;
+}
+
+function addHours(date, h) {
+  return new Date(date.getTime() + h * 3600 * 1000);
+}
+
+function randInt(min, max) {
+  return Math.floor(Math.random() * (max - min + 1)) + min;
+}
+
+function pickWeighted(items) {
+  const sum = items.reduce((a, b) => a + b.w, 0);
+  let r = Math.random() * sum;
+  for (const it of items) {
+    r -= it.w;
+    if (r <= 0) return it.value;
+  }
+  return items[items.length - 1].value;
+}
+
+function toISO(d) {
+  return d.toISOString();
+}
+
+function clampEnd(end, maxEnd) {
+  return end > maxEnd ? maxEnd : end;
+}
+
+function genContinuousTimeline(kind) {
+  const base = getBaseDate();
+  const endMax = addHours(base, TIMELINE_HOURS);
+
+  const blocks = [];
+  let cursor = new Date(base);
+
+  while (cursor < endMax) {
+    let type;
+    let durationH;
+    let label;
+
+    if (kind === "sofor") {
+      type = pickWeighted([
+        { value: "fuvar", w: 55 },
+        { value: "piheno", w: 25 },
+        { value: "szabadsag", w: 10 },
+        { value: "beteg", w: 10 }
+      ]);
+
+      if (type === "fuvar") {
+        durationH = randInt(4, 14);
+        label = "Fuvar";
+      } else if (type === "piheno") {
+        durationH = randInt(6, 12);
+        label = "Pihenő";
+      } else if (type === "szabadsag") {
+        durationH = randInt(12, 36);
+        label = "Szabadság";
+      } else {
+        durationH = randInt(24, 48); // beteg min 24h
+        label = "Betegszab.";
+      }
+    } else if (kind === "vontato") {
+      type = pickWeighted([
+        { value: "fuvar", w: 65 },
+        { value: "szerviz", w: 20 },
+        { value: "allas", w: 15 }
+      ]);
+
+      if (type === "fuvar") {
+        durationH = randInt(6, 16);
+        label = "Fuvar";
+      } else if (type === "szerviz") {
+        durationH = randInt(6, 24);
+        label = "Szerviz";
+      } else {
+        durationH = randInt(4, 18);
+        label = "Állás";
+      }
+    } else {
+      // potkocsi
+      type = pickWeighted([
+        { value: "fuvar", w: 60 },
+        { value: "szerviz", w: 20 },
+        { value: "standby", w: 20 }
+      ]);
+
+      if (type === "fuvar") {
+        durationH = randInt(6, 16);
+        label = "Fuvar";
+      } else if (type === "szerviz") {
+        durationH = randInt(6, 24);
+        label = "Szerviz";
+      } else {
+        durationH = randInt(4, 24);
+        label = "Standby";
+      }
+    }
+
+    const start = new Date(cursor);
+    const end = clampEnd(addHours(start, durationH), endMax);
+
+    blocks.push({
+      start: toISO(start),
+      end: toISO(end),
+      type,
+      label
+    });
+
+    cursor = new Date(end);
+  }
+
+  if (blocks.length === 0) {
+    blocks.push({
+      start: toISO(base),
+      end: toISO(endMax),
+      type: kind === "sofor" ? "piheno" : "standby",
+      label: "N/A"
+    });
+  }
+
+  return blocks;
+}
+
+function ensureForList(list, kind) {
+  list.forEach((r) => {
+    if (!r.timeline) r.timeline = [];
+    if (r.timeline.length === 0) {
+      r.timeline = genContinuousTimeline(kind);
+    }
+  });
+}
+
+export function ensureContinuousTimelines(SOFOROK, VONTATOK, POTKOCSIK) {
+  ensureForList(SOFOROK, "sofor");
+  ensureForList(VONTATOK, "vontato");
+  ensureForList(POTKOCSIK, "potkocsi");
+}
